{
  "name": "ecommerce-mern",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack MERN eCommerce app with dynamic MongoDB data, auth, checkout, payments, and orders.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "preview": "npm run preview -w client",
    "start": "npm run start -w server",
    "seed": "npm run seed -w server",
    "create-admin": "npm run create-admin -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
